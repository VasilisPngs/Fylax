<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Fylax</AssemblyName>
    <RootNamespace>Fylax</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <Version>1.0.0</Version>
  </PropertyGroup>
  <ItemGroup>
    <Using Remove="System.Windows.Forms" />
    <Using Remove="System.Drawing" />
  </ItemGroup>
  <ItemGroup>
    <Resource Include="app.ico" />
    <Resource Include="Fonts\GoogleSansFlexRounded-Regular.ttf" />
    <Resource Include="Fonts\GoogleSansFlexRounded-Medium.ttf" />
    <Resource Include="Fonts\GoogleSansFlexRounded-Bold.ttf" />
  </ItemGroup>
</Project>
